# ─── Database ───────────────────────────────────────────────────────────────
# Local dev (docker-compose): postgresql://flashy:flashy@localhost:5433/flashy?schema=public
# (port 5433, not 5432 — avoids clashing with other local Postgres containers)
# Deploy (Neon): use the DIRECT (unpooled) connection string — host WITHOUT
# "-pooler". A single always-on server holds one small pool itself, so
# PgBouncer buys nothing and can cause subtle issues with Prisma's adapter.
DATABASE_URL="postgresql://flashy:flashy@localhost:5433/flashy?schema=public"

# ─── Auth ────────────────────────────────────────────────────────────────────
# openssl rand -base64 32
JWT_ACCESS_SECRET="change-me-before-production"
JWT_REFRESH_SECRET="change-me-before-production-too"

# Google OAuth Client ID (Web application type) — used to verify "Sign in
# with Google" ID tokens. Same value as the frontend's
# NEXT_PUBLIC_GOOGLE_CLIENT_ID; no client secret is needed for this flow.
# See README.md "Google sign-in setup" for how to create one.
GOOGLE_CLIENT_ID=""

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the web/PWA client.
CORS_ORIGIN="http://localhost:3000"

# ─── AI grading ──────────────────────────────────────────────────────────────
# Used by POST /grade to call Claude for AI-assisted test-mode grading.
ANTHROPIC_API_KEY=""
